{
  "info": {
    "_postman_id": "8b2f6f2d-4b09-4f5d-a714-5d58f43d5ab7",
    "name": "Assignment 7 Auth API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Ready-to-run collection for register/login/getme/promote/protected/rate-limit checks"
  },
  "item": [
    {
      "name": "1) Register User A",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"user_a\",\n  \"email\": \"a@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": "{{baseUrl}}/users/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 or 500(if already exists)', function () {",
              "    pm.expect([201,500]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2) Register User B",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"user_b\",\n  \"email\": \"b@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": "{{baseUrl}}/users/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 or 500(if already exists)', function () {",
              "    pm.expect([201,500]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3) Register Admin",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin_a\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"
        },
        "url": "{{baseUrl}}/users/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 or 500(if already exists)', function () {",
              "    pm.expect([201,500]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4) Login User A",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"user_a\",\n  \"password\": \"password123\"\n}"
        },
        "url": "{{baseUrl}}/users/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.expect(json.token).to.be.a('string');",
              "pm.environment.set('userAToken', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "5) Login User B",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"user_b\",\n  \"password\": \"password123\"\n}"
        },
        "url": "{{baseUrl}}/users/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.expect(json.token).to.be.a('string');",
              "pm.environment.set('userBToken', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "6) Login Admin",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin_a\",\n  \"password\": \"password123\"\n}"
        },
        "url": "{{baseUrl}}/users/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.expect(json.token).to.be.a('string');",
              "pm.environment.set('adminToken', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "7) GetMe as User A",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userAToken}}" }
        ],
        "url": "{{baseUrl}}/users/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.expect(json.user).to.exist;",
              "pm.environment.set('userAId', json.user.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "8) GetMe as User B",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userBToken}}" }
        ],
        "url": "{{baseUrl}}/users/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "9) Protected Hello (no token, should be 401)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/protected/hello"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    },
    {
      "name": "10) Protected Hello (with token)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userAToken}}" }
        ],
        "url": "{{baseUrl}}/users/protected/hello"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "11) Promote User A as Admin",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"manager\"\n}"
        },
        "url": "{{baseUrl}}/users/promote/{{userAId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "12) Promote User A as User B (should be 403)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userBToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"user\"\n}"
        },
        "url": "{{baseUrl}}/users/promote/{{userAId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 403', function () { pm.response.to.have.status(403); });"
            ]
          }
        }
      ]
    },
    {
      "name": "13) Rate Limit Check (run repeatedly)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userAToken}}" }
        ],
        "url": "{{baseUrl}}/users/protected/hello"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 or 429', function () {",
              "    pm.expect([200,429]).to.include(pm.response.code);",
              "});",
              "console.log('Limit:', pm.response.headers.get('X-RateLimit-Limit'));",
              "console.log('Remaining:', pm.response.headers.get('X-RateLimit-Remaining'));",
              "console.log('Reset:', pm.response.headers.get('X-RateLimit-Reset'));"
            ]
          }
        }
      ]
    }
  ]
}
